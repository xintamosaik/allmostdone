templ DueDateDisplay(id ID, dueDate string) {
	<form
		fx-action={ fmt.Sprintf("/todos/%d/edit/due-date", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#due-date-%d", id) }
		fx-swap="innerHTML">
