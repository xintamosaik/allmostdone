templ CostOfDelayDisplay(id ID, costOfDelay CostOfDelay) {
	<form
		fx-action={ fmt.Sprintf("/todos/%d/edit/cost-of-delay", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#cost-of-delay-%d", id) }
		fx-swap="innerHTML">
		<button type="submit">{ costOfDelay }</button>
	</form>
}

templ CostOfDelayEditor(id ID, costOfDelay CostOfDelay) {
	<form
		fx-action={ fmt.Sprintf("/todos/%d/update/cost-of-delay", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#cost-of-delay-%d", id) }
		fx-swap="innerHTML">
		<button type="submit" name="cost_of_delay" value="-2">-2</button>
		<button type="submit" name="cost_of_delay" value="-1">-1</button>
		<button type="submit" name="cost_of_delay" value="0">0</button>
		<button type="submit" name="cost_of_delay" value="1">1</button>
		<button type="submit" name="cost_of_delay" value="2">2</button>
	</form>
}

templ EffortDisplay(id ID, effort Effort) {
	<form
		fx-action={ fmt.Sprintf("/todos/%d/edit/effort", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#effort-%d", id) }
		fx-swap="innerHTML">
		<button type="submit">{ effort }</button>
	</form>
}

templ EffortEditor(id ID, effort Effort) {
	<form
		fx-action={ fmt.Sprintf("/todos/%d/update/effort", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#effort-%d", id) }
		fx-swap="innerHTML">
		<button type="submit" name="effort" value="mins">mins</button>
		<button type="submit" name="effort" value="hours">hours</button>
		<button type="submit" name="effort" value="days">days</button>
		<button type="submit" name="effort" value="weeks">weeks</button>
		<button type="submit" name="effort" value="months">months</button>
	</form>
}

templ TodoListPage(todos []Todo) {
	<button fx-action="/todos/new" fx-target="#output" fx-swap="innerHTML">
		New todo
	</button>
	<h1>Todo List</h1>
	<table>
		<tr>
			<th>ID</th>
			<th>Short</th>
			<th>Description</th>
			<th>Due Date</th>
			<th>Cost of Delay</th>
			<th>Effort</th>
			<th>Created At</th>
			<th>Updated At</th>
			<th>Actions</th>
		</tr>
			for _, todo := range todos {
				<tr>
					<td>{ todo.ID }</td>
					<td id={ fmt.Sprintf("short-%d", todo.ID) }>
						@ShortDisplay(todo.ID, todo.Short)
					</td>
					<td id={ fmt.Sprintf("description-%d", todo.ID) }>
						@DescriptionDisplay(todo.ID, todo.Description)
					</td>
					<td id={ fmt.Sprintf("due-date-%d", todo.ID) }>
						@DueDateDisplay(todo.ID, todoDisplayDueDate(&todo))
					</td>
					<td id={ fmt.Sprintf("cost-of-delay-%d", todo.ID) }>
						@CostOfDelayDisplay(todo.ID, todo.CostOfDelay)
					</td>
					<td id={ fmt.Sprintf("effort-%d", todo.ID) }>
						@EffortDisplay(todo.ID, todo.Effort)
					</td>
					<td>{ todoDisplayTimestamp(todo.CreatedAt) }</td>
					<td>{ todoDisplayTimestamp(todo.UpdatedAt) }</td>
				<td>
					<button
					fx-action={ fmt.Sprintf("/todos/%d/edit", todo.ID) }
					fx-target="#output"
					fx-swap="innerHTML">
						Edit
					</button>
					<form
					action={ fmt.Sprintf("/todos/%d/delete", todo.ID) }
					method="post"
					fx-action={ fmt.Sprintf("/todos/%d/delete", todo.ID) }
					fx-method="POST"
					fx-target="#output"
					fx-swap="innerHTML"
					style="display:inline">
						<input type="submit" value="Delete"/>
					</form>
					</td>
				</tr>
			}
	</table>
}
