templ TodoListPage(todos []Todo) {
	<button fx-action="/todos/new" fx-target="#output" fx-swap="innerHTML">
		New todo
	</button>
	<h1>Todo List</h1>
	<table>
		<tr>
			<th>ID</th>
			<th>Short</th>
			<th>Desc</th>
			<th>Due Date</th>
			<th>Cost of Delay</th>
			<th>Effort</th>
			<th>Created</th>
			<th>Updated</th>
			<th>Actions</th>
		</tr>
		for _, todo := range todos {
			<tr>
				<td>{ todo.ID }</td>
				<td id={ fmt.Sprintf("short-%d", todo.ID) }>
					@ShortDisplay(todo.ID, todo.Short)
				</td>
				<td id={ fmt.Sprintf("description-%d", todo.ID) }>
					@DescriptionDisplay(todo.ID, todo.Description)
				</td>
				<td id={ fmt.Sprintf("due-date-%d", todo.ID) }>
					@DueDateDisplay(todo.ID, todoDisplayDueDate(&todo))
				</td>
				<td id={ fmt.Sprintf("cost-of-delay-%d", todo.ID) }>
					@CostOfDelayDisplay(todo.ID, todo.CostOfDelay)
				</td>
				<td id={ fmt.Sprintf("effort-%d", todo.ID) }>
					@EffortDisplay(todo.ID, todo.Effort)
				</td>
				<td>
					<time datetime={ todo.CreatedAt.Format(time.RFC3339) } title={ todoDisplayTimestamp(todo.CreatedAt) }>
						{ todoRelativeTime(todo.CreatedAt) }
					</time>
				</td>
				<td>
					<time datetime={ todo.UpdatedAt.Format(time.RFC3339) } title={ todoDisplayTimestamp(todo.UpdatedAt) }>
						{ todoRelativeTime(todo.UpdatedAt) }
					</time>
				</td>
				<td>
					<button
						fx-action={ fmt.Sprintf("/todos/%d/edit", todo.ID) }
						fx-target="#output"
						fx-swap="innerHTML">
						Edit
					</button>
					<form
						action={ fmt.Sprintf("/todos/%d/delete", todo.ID) }
						method="post"
						fx-action={ fmt.Sprintf("/todos/%d/delete", todo.ID) }
						fx-method="POST"
						fx-target="#output"
						fx-swap="innerHTML"
						style="display:inline">
						<input type="submit" value="Delete"/>
					</form>
				</td>
			</tr>
		}
	</table>
}
