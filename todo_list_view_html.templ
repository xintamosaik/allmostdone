templ DueDateEditor(id ID, dueDate string) {
	<form
		fx-action={ fmt.Sprintf("/todos/%d/update/due-date", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#due-date-%d", id) }
		fx-swap="innerHTML">
