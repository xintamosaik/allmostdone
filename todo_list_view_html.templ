}

templ DescriptionEditor(id ID, description Description) {
	<form
		fx-action={ fmt.Sprintf("/todos/%d/update/description", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#description-%d", id) }
		fx-swap="innerHTML">
		<input type="text" name="description" value={ description }/>
