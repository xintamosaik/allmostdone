package main

import (
	"fmt"
	"time"
)

func todoDisplayTimestamp(ts time.Time) string {
	return ts.Format("2006-01-02 15:04:05")
}

func todoRelativeTime(ts time.Time) string {
	d := time.Since(ts)
	if d < 0 {
		d = 0
	}
	if d < time.Minute {
		return "just now"
	}
	if d < time.Hour {
		return fmt.Sprintf("%d min ago", int(d/time.Minute))
	}
	if d < 24*time.Hour {
		return fmt.Sprintf("%d h ago", int(d/time.Hour))
	}
	return fmt.Sprintf("%d d ago", int(d/(24*time.Hour)))
}

func todoPreviewText(s string, maxLen int) string {
	if len(s) <= maxLen {
		return s
	}
	if maxLen <= 3 {
		return s[:maxLen]
	}
	return s[:maxLen-3] + "..."
}

func todoDisplayDueDate(todo *Todo) string {
	if todo == nil || todo.DueDate == nil {
		return "N/A"
	}
	return todo.DueDate.Format("2006-01-02")
}

func todoInputDueDateForCell(dueDate DueDate) string {
	if dueDate == nil {
		return ""
	}
	return dueDate.Format("2006-01-02")
}

templ ShortDisplay(id ID, short Short) {
	<button
		type="button"
		style="width: 100%"
		fx-action={ fmt.Sprintf("/todos/%d/edit/short", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#short-%d", id) }
		fx-swap="innerHTML"
		aria-label={ fmt.Sprintf("Edit short for todo %d", id) }>
		{ short }
	</button>
}

templ ShortEditor(id ID, short Short) {
	<form
	    style="display:flex; flex-direction: column; align-items: stretch; width: 16ch"
		fx-action={ fmt.Sprintf("/todos/%d/update/short", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#short-%d", id) }
		fx-swap="innerHTML">
		<input type="text" name="short" value={ short }/>
		<button type="submit">Save</button>
	</form>
}

templ DescriptionDisplay(id ID, description Description) {
	<button
		type="button"
		style="width: 100%"
		fx-action={ fmt.Sprintf("/todos/%d/edit/description", id) }
		fx-method="POST"
		fx-target={ fmt.Sprintf("#description-%d", id) }
		fx-swap="innerHTML"
		aria-label={ fmt.Sprintf("Edit description for todo %d", id) }>
		{ todoPreviewText(description, 24) }
	</button>
}

templ DescriptionEditor(id ID, description Description) {
	<form
	    style="display:flex; flex-direction: column; align-items: stretch"
