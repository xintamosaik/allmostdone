package main

import (
	"fmt"
	"time"
)

func todoDisplayTimestamp(ts time.Time) string {
	return ts.Format("2006-01-02 15:04:05")
}

func todoRelativeTime(ts time.Time) string {
	d := time.Since(ts)
	if d < 0 {
		d = 0
	}
	if d < time.Minute {
		return "just now"
	}
	if d < time.Hour {
		return fmt.Sprintf("%d min ago", int(d/time.Minute))
	}
	if d < 24*time.Hour {
		return fmt.Sprintf("%d h ago", int(d/time.Hour))
	}
	return fmt.Sprintf("%d d ago", int(d/(24*time.Hour)))
}

func todoPreviewText(s string, maxLen int) string {
	if len(s) <= maxLen {
		return s
	}
	if maxLen <= 3 {
		return s[:maxLen]
	}
	return s[:maxLen-3] + "..."
}

func todoDisplayDueDate(todo *Todo) string {
	if todo == nil || todo.DueDate == nil {
		return "N/A"
	}
	return todo.DueDate.Format("2006-01-02")
}

templ TodoListPage(todos []Todo) {
	<button fx-action="/todos/new" fx-target="#output" fx-swap="innerHTML">
		New todo
	</button>
	<h1>Todo List</h1>
	<div id="todos" class="todo-grid" role="table" aria-label="Todo list">
		<div class="todo-grid-header" role="row">
			<div role="columnheader">ID</div>
			<div role="columnheader">Short</div>
			<div role="columnheader">Desc</div>
			<div role="columnheader">Due Date</div>
			<div role="columnheader">Cost of Delay</div>
			<div role="columnheader">Effort</div>
			<div role="columnheader">Created</div>
			<div role="columnheader">Updated</div>
			<div role="columnheader">Actions</div>
		</div>
		for _, todo := range todos {
			<article class="todo-grid-row" role="row">
				<div class="todo-grid-cell" data-label="ID" role="cell">
					<span class="todo-grid-label">ID</span>
					<span>{ todo.ID }</span>
				</div>
				<div class="todo-grid-cell" data-label="Short" role="cell">
					<span class="todo-grid-label">Short</span>
					<div id={ fmt.Sprintf("short-%d", todo.ID) }>
						@ShortDisplay(todo.ID, todo.Short)
					</div>
				</div>
				<div class="todo-grid-cell" data-label="Desc" role="cell">
					<span class="todo-grid-label">Desc</span>
					<div id={ fmt.Sprintf("description-%d", todo.ID) }>
						@DescriptionDisplay(todo.ID, todo.Description)
					</div>
				</div>
				<div class="todo-grid-cell" data-label="Due Date" role="cell">
					<span class="todo-grid-label">Due Date</span>
					<div id={ fmt.Sprintf("due-date-%d", todo.ID) }>
						@DueDateDisplay(todo.ID, todoDisplayDueDate(&todo))
					</div>
				</div>
				<div class="todo-grid-cell" data-label="Cost of Delay" role="cell">
					<span class="todo-grid-label">Cost of Delay</span>
					<div id={ fmt.Sprintf("cost-of-delay-%d", todo.ID) }>
						@CostOfDelayDisplay(todo.ID, todo.CostOfDelay)
					</div>
				</div>
				<div class="todo-grid-cell" data-label="Effort" role="cell">
					<span class="todo-grid-label">Effort</span>
					<div id={ fmt.Sprintf("effort-%d", todo.ID) }>
						@EffortDisplay(todo.ID, todo.Effort)
					</div>
				</div>
				<div class="todo-grid-cell" data-label="Created" role="cell">
					<span class="todo-grid-label">Created</span>
					<time datetime={ todo.CreatedAt.Format(time.RFC3339) } title={ todoDisplayTimestamp(todo.CreatedAt) }>
						{ todoRelativeTime(todo.CreatedAt) }
					</time>
				</div>
				<div class="todo-grid-cell" data-label="Updated" role="cell">
					<span class="todo-grid-label">Updated</span>
					<time datetime={ todo.UpdatedAt.Format(time.RFC3339) } title={ todoDisplayTimestamp(todo.UpdatedAt) }>
						{ todoRelativeTime(todo.UpdatedAt) }
					</time>
				</div>
				<div class="todo-grid-cell todo-grid-actions" data-label="Actions" role="cell">
					<span class="todo-grid-label">Actions</span>
					<button
						fx-action={ fmt.Sprintf("/todos/%d/edit", todo.ID) }
						fx-target="#output"
						fx-swap="innerHTML">
						Edit
					</button>
					<form
						action={ fmt.Sprintf("/todos/%d/delete", todo.ID) }
						method="post"
						fx-action={ fmt.Sprintf("/todos/%d/delete", todo.ID) }
						fx-method="POST"
						fx-target="#output"
						fx-swap="innerHTML"
						style="display:inline">
						<input type="submit" value="Delete"/>
					</form>
				</div>
			</article>
		}
	</div>
}
